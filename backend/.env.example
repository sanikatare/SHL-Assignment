# Scraper Configuration
SCRAPER_BASE_URL=https://www.shl.com
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY=2
# Set to true to also visit each assessment's detail page for a scraped
# description/duration (~370+ extra requests, slower but more complete).
SCRAPE_DETAILS=false

# API Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=true

# Retrieval Weights (see backend/ranking.py combine())
TFIDF_WEIGHT=0.35
CONSTRAINT_WEIGHT=0.2
FUZZY_WEIGHT=0.15
SKILL_OVERLAP_WEIGHT=0.15
ROLE_SIMILARITY_WEIGHT=0.1
TYPE_WEIGHT=0.05
TOP_K_RECOMMENDATIONS=10

# Logging
LOG_LEVEL=INFO

# LLM / RAG layer (backend/llm.py) — OPTIONAL. Leave ANTHROPIC_API_KEY unset
# to run the agent exactly as before (deterministic template replies, no
# network calls, no anthropic dependency required at runtime). Set it to
# enable: (1) grounded RAG prose generated over the already-retrieved
# shortlist, and (2) an LLM fallback for semantic constraint extraction
# when keyword matching finds nothing. Both degrade silently to the
# existing template/keyword behavior on any error, so this is safe to
# toggle at any time.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
LLM_TIMEOUT_SECONDS=8
LLM_MAX_RETRIES=1
